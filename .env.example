# ── Auth0 ────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://nova-demo-api
# Expected provider claim value in the JWT (set by the Revit plugin side)
REVIT_PROVIDER_CLAIM_KEY=https://nova-demo/provider
REVIT_PROVIDER_CLAIM_VALUE=revit-plugin

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
